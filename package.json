{
  "name": "weight-telegram-bot",
  "version": "1.0.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "A nine-language Telegram group bot for weekly weight goals, charts, reminders, and achievements.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "assets:optimize": "tsx scripts/optimize-achievements.ts",
    "assets:validate": "tsx scripts/validate-achievements.ts",
    "assets:contact-sheet": "tsx scripts/create-contact-sheet.ts",
    "assets:chart-example": "tsx scripts/create-chart-example.ts",
    "assets:plan-examples": "tsx scripts/create-plan-examples.ts"
  },
  "dependencies": {
    "@grammyjs/types": "^3.28.0",
    "@napi-rs/canvas": "^1.0.2",
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.10.0",
    "grammy": "^1.44.0",
    "luxon": "^3.7.2",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.11.2",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/luxon": "^3.7.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.0.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.10"
  }
}
